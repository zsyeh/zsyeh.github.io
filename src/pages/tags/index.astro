---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const counts = new Map<string, number>();
posts.flatMap((post) => post.data.tags).forEach((name) => counts.set(name, (counts.get(name) || 0) + 1));
const tags = [...counts].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags">
  <section class="page-head"><span>TAGS</span><h1>Browse by Tag</h1><p>Find relevant articles by keyword.</p></section>
  <div class="tag-cloud">{tags.map(([name, count]) => <a href={`/tags/${encodeURIComponent(name)}/`}>#{name}<small>{count}</small></a>)}</div>
</BaseLayout>
