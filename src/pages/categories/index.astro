---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const counts = new Map<string, number>();
posts.flatMap((post) => post.data.categories).forEach((name) => counts.set(name, (counts.get(name) || 0) + 1));
const categories = [...counts].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="分类">
  <section class="page-head"><span>CATEGORIES</span><h1>文章分类</h1><p>按主题浏览全部内容。</p></section>
  <div class="taxonomy-grid">{categories.map(([name, count]) => <a href={`/categories/${encodeURIComponent(name)}/`}><strong>{name}</strong><span>{count} 篇文章 →</span></a>)}</div>
</BaseLayout>
