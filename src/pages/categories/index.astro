---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const counts = new Map<string, number>();
posts.flatMap((post) => post.data.categories).forEach((name) => counts.set(name, (counts.get(name) || 0) + 1));
const categories = [...counts].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Categories">
  <section class="page-head"><span>CATEGORIES</span><h1>Browse by Category</h1><p>Explore the journal by subject area.</p></section>
  <div class="taxonomy-grid">{categories.map(([name, count]) => <a href={`/categories/${encodeURIComponent(name)}/`}><strong>{name}</strong><span>{count} articles →</span></a>)}</div>
</BaseLayout>
